{
  "framework": null,
  "buildCommand": "cd web && npm install && npx ng build --configuration=production",
  "outputDirectory": "web/dist/web/browser",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://velt-api.onrender.com/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
